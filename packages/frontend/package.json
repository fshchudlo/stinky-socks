{
  "name": "stinky-socks-frontend",
  "author": "Fedor Shchudlo",
  "license": "Apache 2.0",
  "version": "1.0.0",
  "main": "dist/app.js",
  "keywords": [
    "devex",
    "jenkins",
    "github"
  ],
  "scripts": {
    "start": "node --require ts-node/register/transpile-only src/app.ts",
    "build": "tsc -p ../../tsconfig.json",
    "test": "jest --config ../../jest.config.cjs",
    "test:coverage": "jest --config ../../jest.config.cjs --coverage",
    "test:update-snapshots": "jest --config ../../jest.config.cjs --updateSnapshot"
  },
  "dependencies": {
    "@types/express": "5.0.6",
    "@types/express-session": "^1.19.0",
    "@types/passport": "1.0.17",
    "@types/passport-github2": "1.2.9",
    "axios": "1.16.0",
    "express": "5.2.1",
    "express-session": "1.19.0",
    "express-rate-limit": "8.5.0",
    "passport": "0.7.0",
    "passport-github2": "0.1.12"
  }
}
