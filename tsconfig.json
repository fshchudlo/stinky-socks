{
  "compilerOptions": {
    "target": "es2022",
    "module": "preserve",
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "strictNullChecks": true,
    "strictPropertyInitialization": false,
    "sourceMap": true,
    "moduleResolution": "bundler",
    "rootDir": ".",
    "outDir": "./dist",
    "types": [
      "node",
      "jest",
      "express",
      "express-session",
      "passport",
      "passport-github2",
      "jsonwebtoken"
    ],
    "typeRoots": [
      "./node_modules/@types",
      "./types"
    ]
  },
  "ts-node": {
    "compilerOptions": {
      "module": "commonjs"
    }
  },
  "include": [
    "./**/*.ts"
  ],
  "exclude": [
    "./node_modules"
  ]
}
